# =============================================================================
# Quantum Rakshak — Environment Variables
# =============================================================================

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1

# ── Service Ports ────────────────────────────────────────────────────────────
ISSUER_PORT=5001
HOLDER_PORT=5002
VERIFIER_PORT=5003

# ── Hyperledger Fabric ───────────────────────────────────────────────────────
FABRIC_PEER_ADDRESS=localhost:7051
FABRIC_CHANNEL_NAME=rakshakchannel
FABRIC_CHAINCODE_NAME=credential_registry
FABRIC_MSP_ID=Org1MSP
FABRIC_WALLET_PATH=./wallet
FABRIC_CONNECTION_PROFILE=./network/connection.json

# ── Dilithium ────────────────────────────────────────────────────────────────
DILITHIUM_VARIANT=Dilithium3

# ── Holder Storage ───────────────────────────────────────────────────────────
HOLDER_STORAGE_PATH=./storage
